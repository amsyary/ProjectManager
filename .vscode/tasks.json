{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "script",
      "scriptType": "python",
      "path": "",
      "fileName": "main.py",
      "scriptFile": true,
      "script": "py",
      "target": "py",
      "uri": {
        "$mid": 1,
        "fsPath": "a:\\Python\\ProjectManager\\main.py",
        "_sep": 1,
        "path": "/a:/Python/ProjectManager/main.py",
        "scheme": "file"
      },
      "takesArgs": false,
      "problemMatcher": ["$msCompile"],
      "label": "python: main.py"
    },
    {
      "label": "Build: Windows executable",
      "type": "shell",
      "command": "py",
      "args": [
        "-m",
        "PyInstaller",
        "--clean",
        "ProjectManager.spec"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    }
  ]
}
